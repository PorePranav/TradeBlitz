generator client {
  provider = "prisma-client-js"
  output   = "../src/types/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model KycProfile {
  id                 Int               @id @default(autoincrement())
  userId             Int               @unique
  email              String
  firstName          String
  lastName           String
  phoneNumber        String
  dateOfBirth        DateTime
  addressLine        String
  city               String
  state              String
  country            String
  postalCode         String
  nationality        String
  panCardNumber      String
  submissionDate     DateTime          @default(now())
  verificationStatus KYCStatus         @default(PENDING)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  documents          KycUserDocument[]
}

model KycUserDocument {
  id                 Int                 @id @default(autoincrement())
  userId             Int
  documentType       KYCUserDocumentType
  documentNumber     String
  documentUrl        String
  documentExpiry     DateTime?
  verificationStatus KYCStatus           @default(PENDING)
  KycUser            KycProfile          @relation(fields: [userId], references: [id])
}

enum KYCUserDocumentType {
  AADHAAR_CARD
  PAN_CARD
  PASSPORT
  DRIVING_LICENSE
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
}
